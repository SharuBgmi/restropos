# From Meta developer console > WhatsApp > API Setup (used for auto bill-send to owner)
WHATSAPP_TOKEN=your_permanent_access_token
PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# The number that gets 'owner' role automatically on first login, and receives
# bill copies (WhatsApp) + delete-bill OTPs (SMS). International format, no + and no spaces.
OWNER_WHATSAPP_NUMBER=919999999999

GRAPH_API_VERSION=v20.0
PORT=4000

# From turso.tech — makes your data survive Render redeploys/restarts.
# Leave blank to use a local file instead (fine for testing, NOT for Render).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# From fast2sms.com — used to send login OTP and delete-bill OTP via plain SMS.
# Their "OTP route" works in India without needing DLT template registration.
FAST2SMS_API_KEY=
